#Armstrong Number:It is a number where the sum of the cubes of its digits is equal to the number itself.
#Ex:153 ---> 1**3+5**3+3**3 = 1+125+27 = 153

num = int(input("Enter a number: "))
temp = num
sum = 0

while num > 0:
    digit = num % 10
    sum = sum + digit ** 3
    num = num // 10

if temp == sum:
    print(temp, "is an Armstrong Number")
else:
    print(temp, "is not an Armstrong Number")
